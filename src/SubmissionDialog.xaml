<Window x:Class="FieldPulseSIP.SubmissionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FieldPulseSIP"
        Title="Send Report to FieldPulse"
        Width="720" Height="820"
        MinWidth="680" MinHeight="600"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{StaticResource BgMainBrush}"
        Icon="Assets/FP_Icon.png"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header     -->
            <RowDefinition Height="1"/>    <!-- Separator  -->
            <RowDefinition Height="*"/>    <!-- TabControl -->
            <RowDefinition Height="1"/>    <!-- Separator  -->
            <RowDefinition Height="64"/>   <!-- Buttons    -->
        </Grid.RowDefinitions>

        <!-- ── Dialog header ──────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource NavyBrush}" Padding="24,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Onboarding Information"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="Complete all tabs before submitting to FieldPulse."
                           Foreground="#8899CC" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="1" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Tab Control ─────────────────────────────────────────── -->
        <TabControl Grid.Row="2" x:Name="tabControl" Margin="0" Padding="0"
                    Background="{StaticResource BgMainBrush}" BorderThickness="0">

            <!-- ════════════════════════════════════════════════════════
                 TAB 1: PHONE DETAILS
                 ════════════════════════════════════════════════════════ -->
            <TabItem Header="  Phone Details  " Padding="12,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,16,24,16">
                    <StackPanel>

                        <Border Background="{StaticResource NavyTintBrush}" CornerRadius="6"
                                Padding="14,10" Margin="0,0,0,14">
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource TextSecBrush}">
                                Tell us about the phones you'll be using. Don't worry if you're not sure
                                about some of these — just fill in what you can and FieldPulse will help
                                with the rest during your setup call.
                            </TextBlock>
                        </Border>

                        <!-- SECTION: PHONE DETAILS -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ABOUT YOUR PHONES"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource NavyBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Rectangle Grid.Column="1" Height="1"
                                       Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Number of phones -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Number of phones:"
                                       Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <TextBox x:Name="txtPhoneCount"
                                         Style="{StaticResource FlatTextBox}"
                                         MaxLength="50"
                                         ToolTip="e.g. 5, or '1 now, 3 more next month'"/>
                                <TextBlock x:Name="errPhoneCount" Foreground="#CF222E" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Configuration type -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Phone system type:"
                                       Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <ComboBox x:Name="cmbConfigType"
                                          Style="{StaticResource FlatComboBox}"
                                          IsEditable="True" Text="">
                                    <ComboBoxItem>Cloud / Hosted (phone service is online)</ComboBoxItem>
                                    <ComboBoxItem>On-Site System (phone system is in your office)</ComboBoxItem>
                                    <ComboBoxItem>Direct Connection (phones connect straight to provider)</ComboBoxItem>
                                    <ComboBoxItem>Not sure</ComboBoxItem>
                                    <ComboBoxItem>Other</ComboBoxItem>
                                </ComboBox>
                                <TextBlock FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0"
                                           Text="Not sure? Choose 'Not sure' — FieldPulse will figure it out."/>
                                <TextBlock x:Name="errConfigType" Foreground="#CF222E" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Phone brand(s) -->
                        <TextBlock Text="Phone brand(s):" Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,6"/>
                        <Border Background="White" CornerRadius="6" Padding="14,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,4">
                            <StackPanel>
                                <UniformGrid Columns="3">
                                    <CheckBox x:Name="chkBrandYealink"     Content="Yealink"        FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandPolycom"     Content="Polycom / Poly" FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandCisco"       Content="Cisco"          FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandGrandstream" Content="Grandstream"    FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandFanvil"      Content="Fanvil"         FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandSnom"        Content="Snom"           FontSize="12" Margin="0,0,0,8"/>
                                    <CheckBox x:Name="chkBrandObihai"      Content="Obihai"         FontSize="12" Margin="0,0,0,0"/>
                                    <CheckBox x:Name="chkBrandAvaya"       Content="Avaya"          FontSize="12" Margin="0,0,0,0"/>
                                    <CheckBox x:Name="chkBrandMitel"       Content="Mitel"          FontSize="12" Margin="0,0,0,0"/>
                                </UniformGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <CheckBox x:Name="chkBrandOther" Content="Other:"
                                              FontSize="12" VerticalAlignment="Center"
                                              Margin="0,0,10,0" MinWidth="68"/>
                                    <TextBox x:Name="txtBrandOther"
                                             Style="{StaticResource FlatTextBox}"
                                             Width="200" MaxLength="80"
                                             ToolTip="Enter brand name"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="errPhoneBrand" Foreground="#CF222E" FontSize="11"
                                   Margin="0,2,0,8" Visibility="Collapsed"/>

                        <!-- Phone model(s) — add-to-list -->
                        <TextBlock Text="Phone model(s):" Style="{StaticResource FieldLabel}"
                                   Margin="0,2,0,2"/>
                        <TextBlock FontSize="10.5" Foreground="#8C959F" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="Look for a model number on the front or bottom of the phone (e.g. T46S, VVX250, SPA504G). Type it and press Enter or click Add."/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtModelInput" Grid.Column="0"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="80"
                                     ToolTip="e.g. SIP-T46S — press Enter or click Add"
                                     KeyDown="TxtModelInput_KeyDown"/>
                            <Button x:Name="btnAddModel" Grid.Column="2"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Content="+ Add" Height="38"
                                    Click="BtnAddModel_Click"/>
                        </Grid>
                        <TextBlock x:Name="errModel" Foreground="#CF222E" FontSize="11"
                                   Margin="0,0,0,4" Visibility="Collapsed"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Margin="0,0,0,4">
                            <ListBox x:Name="lvModels" BorderThickness="0" Background="White"
                                     MinHeight="44" MaxHeight="100" SelectionMode="Single"
                                     FontSize="13" Padding="4,4"/>
                        </Border>
                        <Button x:Name="btnRemoveModel"
                                Style="{StaticResource SmallDangerButton}"
                                Content="Remove Selected"
                                Width="130" HorizontalAlignment="Right"
                                Margin="0,0,0,14"
                                Click="BtnRemoveModel_Click"/>

                        <!-- MAC / Serial numbers -->
                        <TextBlock Text="Phone identification (optional):"
                                   Style="{StaticResource FieldLabel}" Margin="0,2,0,2"/>
                        <TextBlock FontSize="10.5" Foreground="#8C959F" Margin="0,0,0,6" TextWrapping="Wrap"
                                   Text="If you can find these, great — they're on a sticker on the bottom or back of each phone. If not, skip this and FieldPulse will collect them during setup."/>

                        <!-- Column labels -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MAC Address"   Style="{StaticResource FieldLabel}" Margin="2,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="Serial Number" Style="{StaticResource FieldLabel}" Margin="2,0,0,0"/>
                            <TextBlock Grid.Column="4" Text="Line Label"    Style="{StaticResource FieldLabel}" Margin="2,0,0,0"/>
                        </Grid>

                        <!-- Input row -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtMacInput" Grid.Column="0"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="17"
                                     ToolTip="Hex digits — colons inserted automatically"
                                     TextChanged="TxtMacInput_TextChanged"
                                     KeyDown="TxtMacInput_KeyDown"/>
                            <TextBox x:Name="txtMacSerial" Grid.Column="2"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="40"
                                     ToolTip="Serial number (optional)"/>
                            <TextBox x:Name="txtMacLabel" Grid.Column="4"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="40"
                                     ToolTip="e.g. Front Desk (optional)"/>
                            <Button x:Name="btnAddMac" Grid.Column="6"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Content="+ Add" Height="38"
                                    Click="BtnAddMac_Click"/>
                        </Grid>

                        <TextBlock x:Name="errMac" Foreground="#CF222E" FontSize="11"
                                   Margin="0,0,0,4" Visibility="Collapsed"/>

                        <!-- MAC list -->
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Margin="0,0,0,4">
                            <ListView x:Name="lvMacs" BorderThickness="0" Background="White"
                                      MinHeight="56" MaxHeight="150" SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="MAC Address" Width="170"
                                                        DisplayMemberBinding="{Binding MACAddress}"/>
                                        <GridViewColumn Header="Serial"      Width="120"
                                                        DisplayMemberBinding="{Binding SerialNumber}"/>
                                        <GridViewColumn Header="Label"       Width="130"
                                                        DisplayMemberBinding="{Binding LineLabel}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                        <Button x:Name="btnRemoveMac"
                                Style="{StaticResource SmallDangerButton}"
                                Content="Remove Selected"
                                Width="130" HorizontalAlignment="Right"
                                Margin="0,0,0,10"
                                Click="BtnRemoveMac_Click"/>

                        <!-- CSV bulk entry -->
                        <Border Background="{StaticResource NavyTintBrush}" CornerRadius="6"
                                Padding="14,10" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="Bulk entry via CSV (optional)"
                                           FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource NavyBrush}" Margin="0,0,0,6"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource TextSecBrush}" Margin="0,0,0,8">
                                    Download the template, fill in one phone per row, then upload.
                                    Columns: Brand, PhoneModel, MACAddress, SerialNumber, Extension, LineLabel.
                                </TextBlock>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="btnDownloadTemplate"
                                            Style="{StaticResource SmallPrimaryButton}"
                                            Content="&#x2B07;  Download Template"
                                            Width="160"
                                            Click="BtnDownloadTemplate_Click"/>
                                    <Button x:Name="btnUploadCsv"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="&#x2B06;  Upload CSV"
                                            Height="30" FontSize="12" Padding="14,0"
                                            Width="130" Margin="8,0,0,0"
                                            Click="BtnUploadCsv_Click"/>
                                </StackPanel>
                                <TextBlock x:Name="lblCsvStatus" Margin="0,8,0,0"
                                           FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecBrush}"
                                           Text="No CSV uploaded."/>
                            </StackPanel>
                        </Border>

                        <Rectangle Height="8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════
                 TAB 2: SCHEDULING & ATTENDEES
                 ════════════════════════════════════════════════════════ -->
            <TabItem Header="  Scheduling &amp; Attendees  " Padding="12,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,16,24,16">
                    <StackPanel>

                        <!-- SECTION: SCHEDULING -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SCHEDULING"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource NavyBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Rectangle Grid.Column="1" Height="1"
                                       Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Preferred time -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preferred time:"
                                       Style="{StaticResource FieldLabel}"/>
                            <StackPanel Grid.Column="1">
                                <ComboBox x:Name="cmbPreferredTime"
                                          Style="{StaticResource FlatComboBox}"
                                          IsEditable="True" Text="">
                                    <ComboBoxItem>ASAP</ComboBoxItem>
                                    <ComboBoxItem>Mon–Fri  9:00 AM – 11:45 AM CT</ComboBoxItem>
                                    <ComboBoxItem>Mon–Fri  1:00 PM – 3:00 PM CT</ComboBoxItem>
                                    <ComboBoxItem>Mon–Fri  3:00 PM – 5:00 PM CT</ComboBoxItem>
                                </ComboBox>
                                <TextBlock x:Name="errPreferredTime" Foreground="#CF222E" FontSize="11"
                                           Margin="0,2,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Additional notes -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Additional notes:"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Top" Margin="0,8,0,0"/>
                            <TextBox x:Name="txtConfigNotes" Grid.Column="1"
                                     Style="{StaticResource FlatTextBoxMulti}"
                                     MinHeight="64"
                                     ToolTip="Special requirements, existing phone system details, etc."/>
                        </Grid>

                        <!-- SECTION: ONBOARDING ATTENDEES -->
                        <Grid Margin="0,18,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ONBOARDING ATTENDEES"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource NavyBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Rectangle Grid.Column="1" Height="1"
                                       Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Column labels -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Name"  Style="{StaticResource FieldLabel}" Margin="2,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="Email" Style="{StaticResource FieldLabel}" Margin="2,0,0,0"/>
                        </Grid>

                        <!-- Input row -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtAttendeeName" Grid.Column="0"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="80"
                                     ToolTip="Full name (required)"/>
                            <TextBox x:Name="txtAttendeeEmail" Grid.Column="2"
                                     Style="{StaticResource FlatTextBox}"
                                     MaxLength="120"
                                     ToolTip="Email address (required)"
                                     KeyDown="TxtAttendeeEmail_KeyDown"/>
                            <Button x:Name="btnAddAttendee" Grid.Column="4"
                                    Style="{StaticResource SmallPrimaryButton}"
                                    Content="+ Add" Height="38"
                                    Click="BtnAddAttendee_Click"/>
                        </Grid>

                        <TextBlock x:Name="errAttendee" Foreground="#CF222E" FontSize="11"
                                   Margin="0,0,0,4" Visibility="Collapsed"/>

                        <!-- Attendees list -->
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="5" Margin="0,0,0,4">
                            <ListView x:Name="lvAttendees" BorderThickness="0" Background="White"
                                      MinHeight="56" MaxHeight="180" SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name"  Width="220"
                                                        DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Email" Width="300"
                                                        DisplayMemberBinding="{Binding Email}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock x:Name="errNoAttendees" Foreground="#CF222E" FontSize="11"
                                       Visibility="Collapsed" VerticalAlignment="Center"
                                       Text="At least one attendee is required."/>
                            <Button x:Name="btnRemoveAttendee"
                                    Style="{StaticResource SmallDangerButton}"
                                    Content="Remove Selected"
                                    Width="130" HorizontalAlignment="Right"
                                    Click="BtnRemoveAttendee_Click"/>
                        </StackPanel>

                        <Rectangle Height="8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ════════════════════════════════════════════════════════
                 TAB 3: BEFORE WE BEGIN
                 ════════════════════════════════════════════════════════ -->
            <TabItem Header="  Before We Begin  " Padding="12,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,16,24,16">
                    <StackPanel>

                        <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,0,0,16"
                                   Foreground="{StaticResource TextSecBrush}">
                            Before FieldPulse can set up your phones, we need to make sure a few things
                            are taken care of. Please read each item and check the box if it applies.
                            If you're not sure about something, check it anyway and your FieldPulse
                            representative will walk you through it.
                        </TextBlock>

                        <!-- ── SWITCHING FROM ANOTHER PROVIDER ── -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SWITCHING FROM ANOTHER PHONE COMPANY"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource NavyBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Rectangle Grid.Column="1" Height="1"
                                       Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="White" CornerRadius="6" Padding="18,16"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <!-- New phones option -->
                                <CheckBox x:Name="chkNewPhones"
                                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,14"
                                          AutomationProperties.Name="New phones confirmation">
                                    <StackPanel>
                                        <TextBlock Text="These are brand new phones — I'm not switching from another phone company."
                                                   TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="Check this if you bought new phones and don't have a previous phone provider. Skip the next two items."
                                                   TextWrapping="Wrap" FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </CheckBox>

                                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,14"/>

                                <!-- Phones released from auto-provisioning -->
                                <CheckBox x:Name="chkPhonesReleased"
                                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"
                                          AutomationProperties.Name="Phones released confirmation">
                                    <StackPanel>
                                        <TextBlock Text="My phones have been released from my old provider's auto-provisioning."
                                                   TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0">
                                            When phones are locked to another provider, that provider controls them automatically —
                                            even after a reboot. Your old provider must remove the phones from their system so
                                            FieldPulse can take over. Ask them to release the phones from auto-provisioning.
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Expander Header="  What does my IT team need to know?" Margin="24,2,0,14"
                                          FontSize="10.5" Foreground="#0550AE" IsExpanded="False">
                                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#57606A" Margin="4,4,0,4">
                                        Previous provider must deprovision all devices: remove SIP registrations,
                                        clear auto-provisioning server URLs (DHCP Option 66 / Option 160), and
                                        delete any zero-touch provisioning redirect records (RPS/GDMS/ZTP) from
                                        the manufacturer's portal. Without this, phones will re-register to the
                                        old provider on every reboot.
                                    </TextBlock>
                                </Expander>

                                <!-- Provisioning passwords -->
                                <CheckBox x:Name="chkProvisioningPasswords"
                                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"
                                          AutomationProperties.Name="Provisioning passwords confirmation">
                                    <StackPanel>
                                        <TextBlock Text="If my phones have a setup password from my old provider, I have that password or it's been removed."
                                                   TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0">
                                            Some phone companies lock the phone settings with a password. If your old provider did this,
                                            you'll need that password so FieldPulse can access the phone's settings, or ask your old provider
                                            to remove the password before they disconnect your service.
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Expander Header="  What does my IT team need to know?" Margin="24,2,0,14"
                                          FontSize="10.5" Foreground="#0550AE" IsExpanded="False">
                                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#57606A" Margin="4,4,0,4">
                                        Obtain or clear: web UI admin password, provisioning server credentials,
                                        and any configuration encryption keys. For Polycom devices, check for
                                        a provisioning server lock in Settings > Provisioning Server. For Yealink,
                                        check Auto Provision > Config Encryption. For Cisco, check the TFTP
                                        configuration lock. Document all credentials and share with FieldPulse
                                        during onboarding.
                                    </TextBlock>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <!-- ── PHONE PREPARATION ── -->
                        <Grid Margin="0,14,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="GETTING YOUR PHONES READY"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource NavyBrush}"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Rectangle Grid.Column="1" Height="1"
                                       Fill="{StaticResource BorderBrush}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Background="White" CornerRadius="6" Padding="18,16"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,6">
                            <StackPanel>
                                <!-- Factory reset -->
                                <CheckBox x:Name="chkFactoryReset"
                                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"
                                          AutomationProperties.Name="Factory reset confirmation">
                                    <StackPanel>
                                        <TextBlock Text="I will reset my phones to factory settings before the setup call (or they're already reset)."
                                                   TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0">
                                            A factory reset clears all old settings from the phone so FieldPulse can start fresh.
                                            This is like wiping a phone back to "out of the box" condition. Your FieldPulse rep can
                                            walk you through how to do this for your specific phone brand.
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Expander Header="  What does my IT team need to know?" Margin="24,2,0,14"
                                          FontSize="10.5" Foreground="#0550AE" IsExpanded="False">
                                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#57606A" Margin="4,4,0,4">
                                        Factory reset clears residual SIP registrations, cached credentials,
                                        and stale provisioning URLs. For Yealink: long-press OK > Factory Reset.
                                        For Polycom: Settings > Advanced (pw: 456) > Admin Settings > Reset to Default.
                                        For Cisco: Settings > Device Administration > Factory Reset.
                                        After reset, phones should show a setup wizard or "No Service" screen.
                                    </TextBlock>
                                </Expander>

                                <!-- Firmware -->
                                <CheckBox x:Name="chkFirmware"
                                          FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                          Margin="0,0,0,4"
                                          AutomationProperties.Name="Firmware update confirmation">
                                    <StackPanel>
                                        <TextBlock Text="I will make sure my phones are updated to the latest software version before the setup call."
                                                   TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#8C959F" Margin="0,3,0,0">
                                            Phone manufacturers release updates that fix bugs and improve call quality.
                                            Having the latest version makes setup smoother. If you're not sure how to update,
                                            FieldPulse can help during your setup call.
                                        </TextBlock>
                                    </StackPanel>
                                </CheckBox>
                                <Expander Header="  What does my IT team need to know?" Margin="24,2,0,8"
                                          FontSize="10.5" Foreground="#0550AE" IsExpanded="False">
                                    <TextBlock TextWrapping="Wrap" FontSize="10.5" Foreground="#57606A" Margin="4,4,0,4">
                                        Update firmware to the latest stable release from the manufacturer
                                        (not beta/RC). Check: Yealink support.yealink.com, Polycom
                                        support.polycom.com, Cisco software.cisco.com, Grandstream
                                        firmware.grandstream.com. Current firmware ensures TLS 1.2 support,
                                        modern codec negotiation, and compatibility with FieldPulse
                                        provisioning templates.
                                    </TextBlock>
                                </Expander>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="errConfirmations" Foreground="#CF222E" FontSize="11"
                                   Margin="0,4,0,8" Visibility="Collapsed"
                                   Text="Please review and check all applicable boxes above."/>

                        <!-- Global error banner -->
                        <Border x:Name="pnlGlobalError" Background="#FFEBE9" CornerRadius="6"
                                Padding="12,8" Margin="0,4,0,8" Visibility="Collapsed"
                                BorderBrush="#CF222E" BorderThickness="1">
                            <TextBlock x:Name="lblGlobalError" Foreground="#CF222E" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Rectangle Height="8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Separator -->
        <Rectangle Grid.Row="3" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Button row ──────────────────────────────────────────── -->
        <Border Grid.Row="4" Background="White" Padding="24,12">
            <DockPanel LastChildFill="False">
                <Button x:Name="btnCancel"
                        DockPanel.Dock="Left"
                        Style="{StaticResource SecondaryButton}"
                        Content="Cancel" Width="100"
                        Click="BtnCancel_Click"
                        AutomationProperties.Name="Cancel submission"/>
                <Button x:Name="btnSubmit"
                        DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButton}"
                        Content="&#x2709;   Send to FieldPulse"
                        Width="190"
                        Click="BtnSubmit_Click"
                        AutomationProperties.Name="Submit report to FieldPulse"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
