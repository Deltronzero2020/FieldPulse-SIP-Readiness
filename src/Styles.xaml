<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FieldPulseSIP">

    <!-- ── Converters ─────────────────────────────────────────── -->
    <local:StatusToAccentBrushConverter   x:Key="AccentBrush"/>
    <local:StatusToBadgeBrushConverter    x:Key="BadgeBrush"/>
    <local:StatusToBadgeTextConverter     x:Key="BadgeText"/>
    <local:BoolToVisibilityConverter      x:Key="BoolVis"/>
    <local:InverseBoolToVisibilityConverter x:Key="InvBoolVis"/>
    <local:ResultTemplateSelector         x:Key="ResultSelector"/>

    <!-- ── Brand palette ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="NavyBrush"        Color="#00034D"/>
    <SolidColorBrush x:Key="NavyHoverBrush"   Color="#0D1A6E"/>
    <SolidColorBrush x:Key="NavyTintBrush"    Color="#E8EAF6"/>
    <SolidColorBrush x:Key="BgMainBrush"      Color="#F6F8FA"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgStripBrush"     Color="#EAECF0"/>
    <SolidColorBrush x:Key="BorderBrush"      Color="#D0D7DE"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1C2226"/>
    <SolidColorBrush x:Key="TextSecBrush"     Color="#57606A"/>
    <SolidColorBrush x:Key="PassBrush"        Color="#1A7F37"/>
    <SolidColorBrush x:Key="WarnBrush"        Color="#9A6700"/>
    <SolidColorBrush x:Key="FailBrush"        Color="#CF222E"/>
    <SolidColorBrush x:Key="InfoBrush"        Color="#0550AE"/>

    <!-- ── Typography ─────────────────────────────────────────── -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas</FontFamily>

    <!-- ── Primary button ─────────────────────────────────────── -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"   Value="#00034D"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="FontFamily"   Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"     Value="13"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Height"       Value="40"/>
        <Setter Property="Padding"      Value="22,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#0D1A6E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#000230"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#B0B8D0"/>
                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Secondary button ───────────────────────────────────── -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background"      Value="#FFFFFF"/>
        <Setter Property="Foreground"      Value="#1C2226"/>
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Height"          Value="40"/>
        <Setter Property="Padding"         Value="22,0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"     Value="#D0D7DE"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F6F8FA"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Small action button (attendee Add / Remove) ────────── -->
    <Style x:Key="SmallPrimaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Height"   Value="30"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding"  Value="14,0"/>
    </Style>

    <Style x:Key="SmallDangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Height"     Value="30"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Padding"    Value="14,0"/>
        <Setter Property="Foreground" Value="#CF222E"/>
        <Setter Property="BorderBrush" Value="#F0A0A8"/>
    </Style>

    <!-- ── Flat TextBox ───────────────────────────────────────── -->
    <Style x:Key="FlatTextBox" TargetType="TextBox">
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Foreground"      Value="#1C2226"/>
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="#D0D7DE"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,9"/>
        <Setter Property="MinHeight"       Value="38"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#00034D"/>
                            <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Multiline variant -->
    <Style x:Key="FlatTextBoxMulti" TargetType="TextBox" BasedOn="{StaticResource FlatTextBox}">
        <Setter Property="Height"                   Value="Auto"/>
        <Setter Property="AcceptsReturn"            Value="True"/>
        <Setter Property="TextWrapping"             Value="Wrap"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="Padding"                  Value="8,8"/>
    </Style>

    <!-- ── Flat ComboBox ──────────────────────────────────────── -->
    <Style x:Key="FlatComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Height"      Value="38"/>
        <Setter Property="Padding"     Value="8,9"/>
        <Setter Property="Background"  Value="White"/>
        <Setter Property="BorderBrush" Value="#D0D7DE"/>
        <Setter Property="Foreground"  Value="#1C2226"/>
        <Setter Property="IsEditable"  Value="True"/>
    </Style>

    <!-- ── Field label ────────────────────────────────────────── -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="Foreground"  Value="#57606A"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ── Result section header template ─────────────────────── -->
    <DataTemplate x:Key="SectionTemplate">
        <Grid Margin="0,16,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding SectionTitle}"
                       FontFamily="{StaticResource AppFont}" FontSize="11"
                       FontWeight="Bold" Foreground="#00034D" VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <Rectangle Grid.Column="1" Height="1" Fill="#D0D7DE"
                       VerticalAlignment="Center"/>
        </Grid>
    </DataTemplate>

    <!-- ── Result card template ───────────────────────────────── -->
    <DataTemplate x:Key="ResultCardTemplate">
        <Border Margin="0,2" CornerRadius="6" Background="White"
                BorderBrush="#E6E9EC" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.06" Direction="270"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Accent left bar -->
                <Border Grid.Column="0" CornerRadius="6,0,0,6"
                        Background="{Binding Status, Converter={StaticResource AccentBrush}}"/>

                <!-- Content -->
                <StackPanel Grid.Column="1" Margin="14,9,10,9">
                    <TextBlock Text="{Binding Category}"
                               FontFamily="{StaticResource AppFont}" FontSize="13"
                               FontWeight="SemiBold" Foreground="#1C2226"/>
                    <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                               FontFamily="{StaticResource AppFont}" FontSize="11.5"
                               Foreground="#57606A" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Status badge -->
                <Border Grid.Column="2" Margin="0,0,14,0" VerticalAlignment="Center"
                        Background="{Binding Status, Converter={StaticResource BadgeBrush}}"
                        CornerRadius="12" Padding="10,4">
                    <TextBlock Text="{Binding Status, Converter={StaticResource BadgeText}}"
                               FontFamily="{StaticResource AppFont}" FontSize="10"
                               FontWeight="Bold"
                               Foreground="{Binding Status, Converter={StaticResource AccentBrush}}"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- ── Thin scrollbar ─────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
