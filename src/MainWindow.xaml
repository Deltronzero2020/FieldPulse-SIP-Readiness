<Window x:Class="FieldPulseSIP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FieldPulseSIP"
        Title="FieldPulse SIP Readiness Check"
        Width="900" Height="740"
        MinWidth="900" MinHeight="740"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource BgMainBrush}"
        Icon="Assets/FP_Icon.png">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>   <!-- Header          -->
            <RowDefinition Height="34"/>   <!-- Meta strip      -->
            <RowDefinition Height="1"/>    <!-- Separator       -->
            <RowDefinition Height="60"/>   <!-- Company input   -->
            <RowDefinition Height="1"/>    <!-- Separator       -->
            <RowDefinition Height="*"/>    <!-- Results         -->
            <RowDefinition Height="5"/>    <!-- Progress bar    -->
            <RowDefinition Height="28"/>   <!-- Status text     -->
            <RowDefinition Height="1"/>    <!-- Separator       -->
            <RowDefinition Height="64"/>   <!-- Buttons         -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource NavyBrush}">
            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Image Source="Assets/FP_Logo_Primary_White.png"
                           Height="40" HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="SIP Phone Registration Readiness Check"
                               Foreground="#8899CC" FontSize="11"
                               Margin="2,5,0,0"/>
                </StackPanel>

                <!-- Version badge -->
                <Border Grid.Column="1" HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#FFFFFF18" CornerRadius="4"
                        Padding="10,4">
                    <TextBlock Text="v2.0" Foreground="#AABBDD"
                               FontSize="11" FontFamily="Consolas"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Meta strip ──────────────────────────────────────── -->
        <Border Grid.Row="1" Background="{StaticResource BgStripBrush}">
            <TextBlock x:Name="lblMeta" VerticalAlignment="Center"
                       Margin="28,0" FontSize="11"
                       Foreground="{StaticResource TextSecBrush}"/>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="2" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Company name input ──────────────────────────────── -->
        <Border Grid.Row="3" Background="White" Padding="28,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MaxWidth="500"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Your company name:"
                           Style="{StaticResource FieldLabel}"
                           Width="148"
                           AutomationProperties.Name="Company name label"/>
                <TextBox Grid.Column="1" x:Name="txtCompanyName"
                         Style="{StaticResource FlatTextBox}"
                         MaxLength="100"
                         AutomationProperties.Name="Company name"
                         AutomationProperties.HelpText="Enter your company name for the readiness report"/>
            </Grid>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="4" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Results area ────────────────────────────────────── -->
        <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BgMainBrush}"
                      Padding="20,12,20,12">
            <StackPanel>

                <!-- Welcome card (shown until checks run) -->
                <Border x:Name="pnlWelcome" Background="White"
                        CornerRadius="8" Padding="28,24"
                        BorderBrush="#E6E9EC" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Ready to check your network"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource NavyBrush}"/>
                        <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecBrush}" FontSize="13" LineHeight="22">
                            This tool makes sure your internet connection is ready for FieldPulse
                            phone service. It runs a quick test and sends the results to your
                            FieldPulse representative.
                            <LineBreak/><LineBreak/>
                            <Bold>Step 1:</Bold>  Type your company name above.
                            <LineBreak/>
                            <Bold>Step 2:</Bold>  Click  <Bold>Run Checks</Bold>.
                            <LineBreak/>
                            <Bold>Step 3:</Bold>  Click  <Bold>Send to FieldPulse</Bold>  when it finishes.
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                            <Border Background="{StaticResource NavyTintBrush}"
                                    CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                                <TextBlock Foreground="{StaticResource NavyBrush}"
                                           FontSize="11" FontWeight="SemiBold">
                                    Takes about 30 seconds
                                </TextBlock>
                            </Border>
                            <Border Background="{StaticResource NavyTintBrush}"
                                    CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                                <TextBlock Foreground="{StaticResource NavyBrush}"
                                           FontSize="11" FontWeight="SemiBold">
                                    No technical knowledge needed
                                </TextBlock>
                            </Border>
                            <Border Background="{StaticResource NavyTintBrush}"
                                    CornerRadius="4" Padding="10,5">
                                <TextBlock Foreground="{StaticResource NavyBrush}"
                                           FontSize="11" FontWeight="SemiBold">
                                    Results sent to your FieldPulse rep
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Dynamic results list -->
                <ItemsControl x:Name="resultsPanel"
                              ItemsSource="{Binding Results}"
                              ItemTemplateSelector="{StaticResource ResultSelector}"
                              Visibility="Collapsed">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>

                <!-- Summary card (shown after checks complete) -->
                <Border x:Name="pnlSummary" Visibility="Collapsed"
                        Margin="0,16,0,0" CornerRadius="8" Padding="20,16"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="lblSummaryTitle"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="lblSummaryDetail"
                                   FontSize="12" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecBrush}" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Visibility="{Binding IsManualActionVisible}">
                            <Border Background="#FFF8C5" CornerRadius="4" Padding="10,6" Margin="0,0,8,0">
                                <TextBlock FontSize="11" Foreground="#9A6700" FontWeight="SemiBold"
                                           Text="⚠  Check your router settings" TextWrapping="Wrap"/>
                            </Border>
                            <Border Background="#FFF8C5" CornerRadius="4" Padding="10,6">
                                <TextBlock FontSize="11" Foreground="#9A6700" FontWeight="SemiBold"
                                           Text="⚠  Reset phones before setup" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Progress bar ─────────────────────────────────────── -->
        <ProgressBar x:Name="progressBar" Grid.Row="6"
                     Minimum="0" Maximum="100" Value="0"
                     Foreground="{StaticResource NavyBrush}"
                     Background="#E8EAF6"
                     BorderThickness="0"
                     IsIndeterminate="False"/>

        <!-- ── Status text ──────────────────────────────────────── -->
        <Border Grid.Row="7" Background="White" Padding="28,0">
            <TextBlock x:Name="lblStatus" Text="Ready."
                       VerticalAlignment="Center" FontSize="11"
                       FontStyle="Italic"
                       Foreground="{StaticResource TextSecBrush}"/>
        </Border>

        <!-- Separator -->
        <Rectangle Grid.Row="8" Fill="{StaticResource BorderBrush}"/>

        <!-- ── Button row ───────────────────────────────────────── -->
        <Border Grid.Row="9" Background="White" Padding="24,12">
            <DockPanel LastChildFill="False">
                <!-- Primary actions — left -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button x:Name="btnRun"
                            Style="{StaticResource PrimaryButton}"
                            Content="▶   Run Checks"
                            Width="150"
                            Click="BtnRun_Click"
                            AutomationProperties.Name="Run network checks"
                            AutomationProperties.HelpText="Execute all network diagnostics to verify SIP phone readiness"/>

                    <Button x:Name="btnSend"
                            Style="{StaticResource PrimaryButton}"
                            Content="✉   Send to FieldPulse"
                            Width="190" Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="BtnSend_Click"
                            AutomationProperties.Name="Send report to FieldPulse"
                            AutomationProperties.HelpText="Submit the readiness report securely to the FieldPulse team"/>

                    <Button x:Name="btnSave"
                            Style="{StaticResource SecondaryButton}"
                            Content="⬇   Save Report"
                            Width="150" Margin="10,0,0,0"
                            IsEnabled="False"
                            Click="BtnSave_Click"
                            AutomationProperties.Name="Save report to desktop"
                            AutomationProperties.HelpText="Save the readiness report as an HTML file to your desktop"/>
                </StackPanel>

                <!-- Utility actions — right -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="btnUserGuide"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnUserGuide_Click"
                            Width="130"
                            AutomationProperties.Name="Open user guide">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2753;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="User Guide" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnITGuide"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnITGuide_Click"
                            Width="150" Margin="8,0,0,0"
                            AutomationProperties.Name="Open IT admin guide">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F6E0;" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="IT Admin Guide" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnClose"
                            Style="{StaticResource SecondaryButton}"
                            Content="Close"
                            Width="80" Margin="8,0,0,0"
                            Click="BtnClose_Click"
                            AutomationProperties.Name="Close application"/>
                </StackPanel>
            </DockPanel>
        </Border>

    </Grid>
</Window>
